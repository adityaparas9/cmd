        <!-- Looks benign — standard HTTP health check -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET Health Endpoint" enabled="true">
          <stringProp name="HTTPSampler.domain">api.target.com</stringProp>
