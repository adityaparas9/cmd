        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Execute whoami Command" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script"><![CDATA[
try {
    // Method 1: Using String.execute()
    def command = "cmd /c whoami"
    def process = command.execute()
    def output = process.text.trim()
    def exitCode = process.exitValue()
    
    // Method 2: More detailed output with error stream
    def process2 = "cmd /c whoami /all".execute()
    process2.waitFor()
    def detailedOutput = process2.in.text.trim()
    def errorOutput = process2.err.text.trim()
    
    // Save results to temp file
    def outputFile = new File("C:/Temp/whoami_output.txt")
    outputFile.getParentFile().mkdirs()
    
    outputFile.text = """COMMAND EXECUTION TEST RESULTS
============================
Timestamp: ${new Date()}
Hostname: ${java.net.InetAddress.localHost.hostName}
Working Directory: ${System.getProperty('user.dir')}

=== WHOAMI OUTPUT ===
${output}

=== WHOAMI /ALL OUTPUT ===
${detailedOutput}

=== ERROR OUTPUT ===
${errorOutput}

=== SYSTEM INFO ===
User: ${System.getProperty('user.name')}
OS: ${System.getProperty('os.name')} ${System.getProperty('os.version')}
Java: ${System.getProperty('java.version')}
"""
    
    log.info("Command executed successfully. Output saved to: " + outputFile.getAbsolutePath())
    log.info("whoami output: " + output)
    
    SampleResult.setSuccessful(true)
    SampleResult.setResponseCodeOK()
    SampleResult.setResponseMessage("SUCCESS: Output saved to " + outputFile.getAbsolutePath() + " | User: " + output)
    SampleResult.setResponseData(output, "UTF-8")
    
} catch (Exception ex) {
    log.error("Command execution failed", ex)
    
    // Try alternate method
    try {
        def process = Runtime.getRuntime().exec("cmd /c whoami > C:/Temp/whoami_alt.txt")
        process.waitFor()
        def altOutput = new File("C:/Temp/whoami_alt.txt").text.trim()
        log.info("Alternate method succeeded: " + altOutput)
        
        SampleResult.setSuccessful(true)
        SampleResult.setResponseCodeOK()
        SampleResult.setResponseMessage("SUCCESS (alt method): " + altOutput)
    } catch (Exception ex2) {
        SampleResult.setSuccessful(false)
        SampleResult.setResponseCode("500")
        SampleResult.setResponseMessage("FAILED: " + ex.toString() + " | Alt: " + ex2.toString())
    }
}
]]></stringProp>
